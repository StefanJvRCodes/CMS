# RabbitMQ Configuration
RABBITMQ_URL=amqp://cms_user:cms_password@localhost:5672/cms_vhost
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=cms_user
RABBITMQ_PASSWORD=cms_password
RABBITMQ_VHOST=cms_vhost

# n8n Configuration
N8N_WEBHOOK_URL=http://localhost:5678/webhook
N8N_API_URL=http://localhost:5678/api

# Application Configuration
APP_NAME="CMS Event-Driven System"
APP_VERSION=1.0.0
DEBUG=true

# Event Configuration
DEFAULT_EXCHANGE=cms_events
DEFAULT_QUEUE=cms_queue